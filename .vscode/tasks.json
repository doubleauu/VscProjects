{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            // 这里的 g++.exe 路径是本机编译器位置，换电脑时需要改成对应机器上的路径。
            // 输出统一放到 workspaceFolder\build\a.exe，方便 launch.json 直接复用。
            "command": "C:\\Program Files (x86)\\cpeditor\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-finput-charset=UTF-8",
                "-fexec-charset=UTF-8",
                "-Wall",
                "-Wextra",
                "${file}",
                "-o",
                "${workspaceFolder}\\build\\a.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        },
        {
            "type": "shell",
            "label": "C/C++: 运行活动文件",
            // 运行任务直接执行 build\a.exe；如果换了输出文件名，这里要一起改。
            "command": "${workspaceFolder}\\build\\a.exe",
            "dependsOn": "C/C++: g++.exe 生成活动文件",
            "problemMatcher": [],
            "group": "test"
        }
    ],
    "version": "2.0.0"
}